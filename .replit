modules = ["nodejs-20", "web", "bash", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["sh", "-c", "NODE_ENV=production pnpm --filter @workspace/api-server run start"]
build = ["sh", "-c", "pnpm install --frozen-lockfile && pnpm --filter @workspace/web-admin build && pnpm --filter @workspace/api-server build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Web Admin"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo Go"

[[workflows.workflow]]
name = "Start Web Admin"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/web-admin && PORT=5000 pnpm dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Start Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && NODE_ENV=development AUTO_SEED=true pnpm exec tsx ./src/dev.ts"
waitForPort = 8080

[[workflows.workflow]]
name = "Expo Go"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/mobile && EXPO_NO_DOTENV=1 EXPO_PUBLIC_API_URL=https://8fcc98ef-c551-4cec-a19b-a551adba3e94-00-2b9md7n83ykc3.pike.replit.dev/api pnpm exec expo start --web --port 8099"
waitForPort = 8099

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["eas-cli"]

[userenv]

[userenv.shared]
CI = "1"
EXPO_NO_DOTENV = "1"
SEED_REAL_DATA = "false"
JWT_SECRET = "f6abfd33b3d2b80c0f5f95a966c729a4a4475f307bd087b3a77911a4c4924327"
API_TARGET = "http://127.0.0.1:8080"
EXPO_PUBLIC_API_URL = "https://8fcc98ef-c551-4cec-a19b-a551adba3e94-00-2b9md7n83ykc3.pike.replit.dev/api"
AUTO_SEED = "false"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8099
externalPort = 8099
