modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["sh", "-c", "NODE_ENV=production pnpm --filter @workspace/api-server run start"]
build = ["sh", "-c", "pnpm install --frozen-lockfile && pnpm --filter @workspace/web-admin build && pnpm --filter @workspace/api-server build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo Go (Tunnel)"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Web Admin"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow]]
name = "Expo Go (Tunnel)"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/mobile && EXPO_NO_DOTENV=1 EXPO_PUBLIC_API_URL=https://f92ca1b9-1262-425b-86f9-4ab60e8e63f0-00-1e5smgthwykj9.sisko.replit.dev/api pnpm exec expo start --web --port 8099 --host lan"
waitForPort = 8099

[[workflows.workflow]]
name = "Start Web Admin"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/web-admin && PORT=5000 API_TARGET=http://localhost:8080 pnpm dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Start Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && NODE_ENV=development AUTO_SEED=true pnpm exec tsx ./src/dev.ts"
waitForPort = 8080

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["eas-cli"]

[userenv]

[userenv.shared]
CI = "1"
EXPO_NO_DOTENV = "1"
AUTO_SEED = "true"
SEED_REAL_DATA = "false"
JWT_SECRET = "f6abfd33b3d2b80c0f5f95a966c729a4a4475f307bd087b3a77911a4c4924327"
API_TARGET = "https://campusops-api-production.up.railway.app"
EXPO_PUBLIC_API_URL = "https://campusops-api-production.up.railway.app/api"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8099
externalPort = 8099
